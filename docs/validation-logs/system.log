===== sysctl tuning =====
# DSLV-ZPDI Kernel Tuning for RF Metrology Pipeline
# Minimize swap pressure (we have 16GB RAM, no need to swap aggressively)
vm.swappiness = 10
# Larger networking buffers for HDF5 streaming / future multi-node
net.core.rmem_max = 26214400
net.core.wmem_max = 26214400
# Reduce kernel log flood from pipeline
kernel.printk = 4 4 1 7
# Protect fifos/regular files
fs.protected_hardlinks = 1
fs.protected_symlinks = 1
fs.protected_fifos = 2
fs.protected_regular = 2
===== modprobe blacklist =====
# DSLV-ZPDI: blacklist DVB driver auto-load to keep RTL-SDR dongles (future) free for SoapySDR
blacklist dvb_usb_rtl28xxu
blacklist rtl2832
blacklist rtl2830
