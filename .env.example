# dslv-zpdi mobile node — environment template
# Copy to .env (gitignored) once the Secure Storage Token is provisioned.

# --- GitHub automation (Phase: post-PAT) ---
GITHUB_PAT=                              # ghp_... — populated from Secure Storage
GITHUB_REMOTE_URL=                       # e.g. https://github.com/<org>/dslv-zpdi.git
GIT_AUTHOR_NAME=dslv-zpdi-node
GIT_AUTHOR_EMAIL=node@dslv-zpdi.local

# --- Edge transport ---
ZPDI_WSS_URI=wss://edge.placeholder.invalid:8443/ingest
ZPDI_WSS_CA_BUNDLE=                      # optional path to org root CA

# --- Local storage ---
ZPDI_HDF5_PATH=./data/zpdi_stream.h5
ZPDI_FALLBACK_LOG=./logs/zpdi_fallback.jsonl

# --- Sampling ---
ZPDI_POLL_INTERVAL_S=0.25                # 4 Hz default
ZPDI_SENSOR_TIMEOUT_S=1.5
