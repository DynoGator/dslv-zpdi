[Unit]
Description=DSLV-ZPDI Baseline Capture (SPEC-009.1)
After=network.target chrony.service

[Service]
Type=simple
User=dynogator
Group=dynogator
WorkingDirectory=/home/dynogator/dslv-zpdi
ExecStart=/home/dynogator/dslv-zpdi/venv/bin/python /home/dynogator/dslv-zpdi/tools/capture_baseline.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=20
ExecStartPre=/bin/sleep 3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=dslv-zpdi-baseline

[Install]
WantedBy=multi-user.target
