#!/bin/bash
# Validate Conventional Commits before local commit creation.

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PYTHON="${REPO_ROOT}/.venv/bin/python"
if [ ! -x "$PYTHON" ]; then
    PYTHON=$(command -v python3 || command -v python)
fi
"$PYTHON" "${REPO_ROOT}/tools/check_commit_message.py" "$1"
